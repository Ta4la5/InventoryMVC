@model List<InventoryMVC.Models.Category>

<button style="
    margin-bottom: 10px;
    margin-top: 10px;
    accent-color
    ">
    <a asp-action="Add">
        Add Category
    </a>
</button>
<h2>Category List</h2>
<table class="table table-bordered table-striped" style="width: 100%">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td width="20%">@category.Name</td>
                <td width="25%">@category.Description</td>
                <td width="15%">
                    <a asp-action="Edit" asp-route-id="@category.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@category.Id" 
                    onclick="return confirm('Are you sure you want to delete this category?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>