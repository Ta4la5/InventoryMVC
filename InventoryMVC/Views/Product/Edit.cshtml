@model InventoryMVC.Models.Product

<h2>Edit Product</h2>
<form method="post" asp-action="Update">
	<input type="hidden" name="Id" value="@Model.Id" />
	<div>
		<label for="Name">Name:</label>
		<input type="text" name="Name" value="@Model.Name" />
	</div>
	<div>
		<label for="Description">Description:</label>
		<input type="text" name="Description" value="@Model.Description" />
	</div>
	<div>
		<label for="CategoryId">Category ID:</label>
		<input type="number" name="CategoryId" value="@Model.CategoryId" />
	</div>
	<div>
		<label for="SupplierId">Supplier ID:</label>
		<input type="number" name="SupplierId" value="@Model.SupplierId" />
	</div>
	<div>
		<label for="UnitPrice">Unit Price:</label>
		<input type="number" step="0.01" name="UnitPrice" value="@Model.UnitPrice" />
	</div>
	<div>
		<label for="QuantityInStock">Quantity In Stock:</label>
		<input type="number" name="QuantityInStock" value="@Model.QuantityInStock" />
	</div>
	<button type="submit">Save Changes</button>
</form>