@model List<InventoryMVC.Models.Supplier>

<h2>Add Supplier</h2>
@if (TempData["SuccessMessage"] != null)
{
	<p>@TempData["SuccessMessage"]</p>
}
<form method="post" asp-action="Save">
	<div>
		<label for="Name">Name:</label>
		<input type="text" name="Name" placeholder="Category Name" />
	</div>
	<div>
		<label for="PhoneNumber">Phone Number:</label>
		<input type="text" name="PhoneNumber" placeholder="Supplier Phone Number" />
	</div>
	<div>
		<label for="Email">Email:</label>
		<input type="email" name="Email" placeholder="Supplier Email" />
	</div>
	<div>
		<label for="Address">Address:</label>
		<input type="text" name="Address" placeholder="Supplier Address" />
	</div>
	<div>
		<label for="Description">Description:</label>
		<input type="text" name="Description" placeholder="Supplier Description" />
	</div>
	<button type="submit">Add Supplier</button>
</form>

<hr